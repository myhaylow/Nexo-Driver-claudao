{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|shell_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command_windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .codex\\hooks\\driver_policy_guard.ps1 -Hook",
            "timeout": 30,
            "statusMessage": "Checking Driver Inteligente guarantees"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command_windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .codex\\hooks\\driver_policy_guard.ps1 -Hook",
            "timeout": 30,
            "statusMessage": "Checking Driver Inteligente guarantees"
          }
        ]
      }
    ]
  }
}
