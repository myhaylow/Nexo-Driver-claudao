## Copy this file to keystore.properties (gitignored) at the project root and fill in real values.
## Generate the keystore yourself, e.g.:
##   keytool -genkey -v -keystore release.keystore -alias nexo-driver -keyalg RSA -keysize 2048 -validity 10000
## Never commit keystore.properties or the .keystore/.jks file.

storeFile=/absolute/path/to/release.keystore
storePassword=
keyAlias=nexo-driver
keyPassword=
